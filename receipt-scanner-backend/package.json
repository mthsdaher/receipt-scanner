{
  "name": "receipt-scanner",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "dev:all": "concurrently -n backend,frontend,ocr -c blue,green,magenta \"npm run dev\" \"npm run start --prefix ../receipt-scanner-frontend\" \"cd ../receipt-scanner-frontend && python -m uvicorn ocr_service:app --reload --host 0.0.0.0 --port 8000\"",
    "seed": "ts-node src/seeds/seed.ts",
    "check:openapi": "node -e \"JSON.parse(require('fs').readFileSync('src/openapi.json','utf8')); console.log('openapi.json is valid');\"",
    "test": "jest --runInBand"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mthsdaher/receipt-scanner.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mthsdaher/receipt-scanner/issues"
  },
  "homepage": "https://github.com/mthsdaher/receipt-scanner#readme",
  "description": "",
  "dependencies": {
    "@types/swagger-ui-express": "^4.1.8",
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.2.1",
    "form-data": "^4.0.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.2",
    "pg": "^8.18.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-validator": "^2.20.33",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.5",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.1.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "ts-jest": "^29.4.4",
    "typescript": "^5.7.3"
  }
}
