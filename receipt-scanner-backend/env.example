NODE_ENV=development
PORT=3002
TRUST_PROXY=false
TRUST_PROXY_HOPS=1
REQUEST_TIMEOUT_MS=30000
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
OCR_UPSTREAM_TIMEOUT_MS=45000
# PostgreSQL connection string - adjust user, password, host, port, database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/receipt_scanner
JWT_SECRET=change-me
OCR_SERVICE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated list for multiple frontend origins
# FRONTEND_URLS=http://localhost:3000,https://your-frontend-domain.com

