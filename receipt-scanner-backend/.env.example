PORT=3002
TRUST_PROXY=false
TRUST_PROXY_HOPS=1
REQUEST_TIMEOUT_MS=30000
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
OCR_UPSTREAM_TIMEOUT_MS=45000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/receipt_scanner
JWT_SECRET=replace-with-a-secure-secret
OCR_SERVICE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated list for multiple frontend origins
# FRONTEND_URLS=http://localhost:3000,https://your-frontend-domain.com

# Google OAuth (optional). If not set, "Sign in with Google" redirects with error.
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorized redirect URI: {BACKEND_PUBLIC_URL}/api/auth/google/callback
#    Example for local: http://localhost:3002/api/auth/google/callback
BACKEND_PUBLIC_URL=http://localhost:3002
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI features (RAG, embeddings, agentic workflows). Required for /api/ai/* endpoints.
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional SMTP configuration (portfolio/demo)
# If configured, reset-request sends a real email via SMTP.
# If not configured, token is returned in API response in non-production only.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@provider.com
SMTP_PASS=your-app-password
SMTP_FROM=Receipt Scanner <no-reply@receipt-scanner.dev>
